// ============================================================
// DataPacket.msg — 自定义消息类型定义文件
// ============================================================
//
// 【本练习新概念】.msg 文件
//
// 问题：cMessage 只有名字和类型，无法携带业务数据（比如地址、序列号）。
//       如果想在消息里附带数据，需要自定义消息类。
//
// 解决方案：写一个 .msg 文件描述消息结构，OMNeT++ 的消息编译器
//   opp_msgc 会自动把它翻译成 C++ 类（.h 和 .cc 文件）。
//   make 时会自动调用 opp_msgc，不需要手动运行。
//
// 生成的文件（自动生成，不要手动修改）：
//   DataPacket_m.h   — 类声明
//   DataPacket_m.cc  — 类实现
//
// 生成的类继承自 cMessage，所以可以当 cMessage* 用，
// 也可以向下转型回 DataPacket* 来访问自定义字段。
// ============================================================

// packet 关键字：声明一个消息类，继承自 cPacket（cMessage 的子类，多了长度字段）
// 也可以用 message 关键字，继承自 cMessage
// 面试题里用 AppPacket，这里我们用 DataPacket，结构完全相同
packet DataPacket
{
    // --------------------------------------------------------
    // 在这里声明消息携带的字段
    // 语法：<类型> <字段名>;
    //
    // 支持的类型：int, long, double, bool, string, 以及其他 msg 定义的类型
    //
    // opp_msgc 会为每个字段生成：
    //   getSrcAddr()  — getter，读取值
    //   setSrcAddr(v) — setter，设置值
    // --------------------------------------------------------

    int srcAddr;    // 发送方的地址（整数）
                    // 对应面试题里的 srcAddr

    int seqNum;     // 序列号，记录这是第几条消息
                    // 面试题里是 destAddr，原理完全相同
}
