// ============================================================
// 应用层数据包定义
// 在 simple_router 基础上增加：
//   ttl       —— 每跳减 1，到 0 即丢弃，防止路由环路死循环
//   hopCount  —— 累计经过的路由器数（统计端到端跳数用）
//   serial    —— 流水号，便于日志追踪单个数据包
// ============================================================
packet AppPacket {
    int  srcAddr;        // 源地址
    int  destAddr;       // 目的地址
    int  ttl;            // 剩余寿命；进入路由器先 -1，<=0 即丢弃
    int  hopCount = 0;   // 已经经过的路由器跳数（初值 0）
    long serial  = 0;    // 流水号，host 端递增
}
